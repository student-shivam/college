PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/predictive_maintenance
MONGO_URI_FALLBACK=mongodb://127.0.0.1:27017/predictive_maintenance
ML_API_URL=http://127.0.0.1:8000
FRONTEND_URL=http://localhost:5173
JWT_SECRET=change_this_to_a_long_random_secret

# Dev-only: seed a default admin on startup (recommended for local demos)
SEED_ADMIN=true
SEED_ADMIN_EMAIL=admin@pm.local
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Admin

# Production notes:
# - On Render, `PORT` is set automatically.
# - Set `NODE_ENV=production` and configure `FRONTEND_URL` to your Netlify URL to enable strict CORS.
# - Set `ML_API_URL` to your deployed ml-api base URL (no `/api` suffix).
